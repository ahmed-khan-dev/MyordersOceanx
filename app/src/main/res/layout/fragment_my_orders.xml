<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_grey">

    <!-- Yellow Header -->
    <LinearLayout
        android:id="@+id/layout_header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/primary_yellow"
        android:orientation="horizontal"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="20dp"
        android:paddingBottom="32dp">

        <!-- Title & Subtitle -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:paddingEnd="8dp">

            <TextView
                android:id="@+id/tv_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/my_orders"
                android:textColor="@color/black"
                android:textSize="26sp"
                android:textStyle="bold"
                android:fontFamily="sans-serif-medium" />

            <TextView
                android:id="@+id/tv_subtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="@string/orders_subtitle"
                android:textColor="@color/black"
                android:textSize="13sp"
                android:lineSpacingMultiplier="1.3" />

        </LinearLayout>

        <!-- Truck Illustration placeholder -->
        <ImageView
            android:id="@+id/iv_truck_illustration"
            android:layout_width="120dp"
            android:layout_height="90dp"
            android:src="@drawable/ic_truck_illustration"
            android:scaleType="fitEnd"
            android:contentDescription="@string/truck_illustration_desc" />

    </LinearLayout>

    <!-- Main Content Card (overlapping header) -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="160dp"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_main_content"
            android:paddingBottom="16dp">

            <!-- Search + Filter + Sort Row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="20dp"
                android:paddingBottom="12dp"
                android:gravity="center_vertical">

                <!-- Search Bar -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_search_bar"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp">

                    <ImageView
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:src="@drawable/ic_search"
                        android:contentDescription="@string/search"
                        app:tint="@color/text_secondary" />

                    <EditText
                        android:id="@+id/et_search"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:layout_marginStart="8dp"
                        android:hint="@string/search_hint"
                        android:textSize="13sp"
                        android:textColorHint="@color/text_hint"
                        android:textColor="@color/text_primary"
                        android:background="@android:color/transparent"
                        android:singleLine="true"
                        android:inputType="text"
                        android:imeOptions="actionSearch" />

                </LinearLayout>

                <!-- Filter Button -->
                <LinearLayout
                    android:id="@+id/btn_filter"
                    android:layout_width="wrap_content"
                    android:layout_height="44dp"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/bg_filter_sort_btn"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:clickable="true"
                    android:focusable="true">

                    <ImageView
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:src="@drawable/ic_filter"
                        android:contentDescription="@string/filter"
                        app:tint="@color/text_primary" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="4dp"
                        android:text="@string/filter"
                        android:textColor="@color/text_primary"
                        android:textSize="13sp" />

                </LinearLayout>

                <!-- Sort Button -->
                <LinearLayout
                    android:id="@+id/btn_sort"
                    android:layout_width="wrap_content"
                    android:layout_height="44dp"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/bg_filter_sort_btn"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:clickable="true"
                    android:focusable="true">

                    <ImageView
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:src="@drawable/ic_sort"
                        android:contentDescription="@string/sort"
                        app:tint="@color/text_primary" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="4dp"
                        android:text="@string/sort"
                        android:textColor="@color/text_primary"
                        android:textSize="13sp" />

                </LinearLayout>

            </LinearLayout>

            <!-- Tab Row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="42dp"
                android:orientation="horizontal"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:background="@color/white">

                <TextView
                    android:id="@+id/tab_all_orders"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="@string/tab_all_orders"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="@drawable/bg_tab_selected"
                    android:textColor="@color/black" />

                <View
                    android:layout_width="1dp"
                    android:layout_height="match_parent"
                    android:background="@color/divider_color" />

                <TextView
                    android:id="@+id/tab_completed"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="@string/tab_completed"
                    android:textSize="13sp"
                    android:clickable="true"
                    android:focusable="true"
                    android:textColor="@color/tab_unselected_text" />

                <View
                    android:layout_width="1dp"
                    android:layout_height="match_parent"
                    android:background="@color/divider_color" />

                <TextView
                    android:id="@+id/tab_cancelled"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="@string/tab_cancelled"
                    android:textSize="13sp"
                    android:clickable="true"
                    android:focusable="true"
                    android:textColor="@color/tab_unselected_text" />

                <View
                    android:layout_width="1dp"
                    android:layout_height="match_parent"
                    android:background="@color/divider_color" />

                <TextView
                    android:id="@+id/tab_booked_again"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="@string/tab_booked_again"
                    android:textSize="12sp"
                    android:clickable="true"
                    android:focusable="true"
                    android:textColor="@color/tab_unselected_text" />

            </LinearLayout>

            <!-- Info Banner -->
            <LinearLayout
                android:id="@+id/layout_info_banner"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_info_banner"
                android:orientation="horizontal"
                android:padding="12dp"
                android:gravity="center_vertical">

                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:src="@drawable/ic_info"
                    android:contentDescription="@string/info"
                    app:tint="@color/info_icon_color" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="10dp"
                    android:text="@string/info_banner_text"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp"
                    android:lineSpacingMultiplier="1.4" />

                <ImageView
                    android:id="@+id/btn_close_banner"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_marginStart="8dp"
                    android:src="@drawable/ic_close"
                    android:contentDescription="@string/close"
                    android:clickable="true"
                    android:focusable="true"
                    android:padding="2dp"
                    app:tint="@color/text_secondary" />

            </LinearLayout>

            <!-- Empty state -->
            <TextView
                android:id="@+id/tv_empty_state"
                android:layout_width="match_parent"
                android:layout_height="200dp"
                android:gravity="center"
                android:text="@string/no_orders_found"
                android:textColor="@color/text_secondary"
                android:textSize="15sp"
                android:visibility="gone"
                tools:visibility="visible" />

            <!-- Orders RecyclerView -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_orders"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:clipToPadding="false"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingBottom="16dp"
                tools:itemCount="3"
                tools:listitem="@layout/item_order" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Help FAB -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fab_help"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_margin="16dp"
        android:layout_marginBottom="16dp"
        android:src="@drawable/ic_headset"
        android:contentDescription="@string/help"
        app:backgroundTint="@color/primary_yellow"
        app:tint="@color/black"
        app:elevation="6dp" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>
